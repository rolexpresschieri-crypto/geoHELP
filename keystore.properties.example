# Copia questo file in keystore.properties e inserisci i valori usati creando la keystore.
# NON mettere keystore.properties su repository o condivisioni (contiene password).
#
# storePassword e keyPassword possono essere uguali (di solito lo sono).
# Usa la stessa password che hai messo creando la keystore con create-keystore.bat
#
storePassword=LA_TUA_PASSWORD
keyPassword=LA_TUA_PASSWORD
keyAlias=geohelp
storeFile=geohelp-release.keystore
