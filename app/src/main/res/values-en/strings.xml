    <!-- Consensi -->
    <string name="consents_title">Consents</string>
    <string name="consents_subtitle">Please read and confirm before continuing.</string>
    <string name="consents_privacy_label">Personal data processing</string>
    <string name="consents_privacy_required">(required)</string>
    <string name="consents_privacy_body">I consent to the processing of my personal data (email, first name, birth year, user phone number, optional profile fields, GPS location when the help request is sent) for the geoHELP service, as described in the privacy notice. This consent is required to use the app.</string>
    <string name="consents_privacy_read_link">Read the full privacy notice (v2)</string>
    <string name="consents_medical_label">Medical data</string>
    <string name="consents_medical_optional">(optional)</string>
    <string name="consents_medical_body">I consent to storing my medical data (conditions, allergies, therapies, pacemaker, notes) on the geoHELP backend, in structured form, protected by per-user security rules (RLS) and encrypted transport (HTTPS). I understand that the data may be accessed by the team operating the service for rescue, support and verification purposes, and may be included in summary form in emergency SMS messages. Access to the medical form on the device is protected by a personal PIN. I can revoke consent at any time.</string>
    <string name="consents_man_down_label">MAN DOWN (fall / impact)</string>
    <string name="consents_man_down_optional">(optional)</string>
    <string name="consents_man_down_body">I consent to using the device motion sensors to detect possible falls or strong impacts and, after a 60-second countdown that I can cancel, to automatically sending emergency SMS to the configured primary and backup numbers (up to 3) with GPS position and essential data, via the geoHELP service (Twilio). I understand false alarms may occur and that sending requires a network connection. I can turn this feature off at any time in the app.</string>
    <string name="consents_continue_btn">CONTINUE</string>
    <string name="consents_save_btn">SAVE CONSENTS</string>
    <string name="consents_cancel_btn">Cancel</string>
    <string name="consents_manage_title">Consents and privacy</string>
    <string name="consents_manage_subtitle">Update or withdraw consents. Each change is stored as a new row on the server.</string>
    <string name="consents_manage_open_btn">Consents and privacy</string>
    <string name="consents_saved_ok">Consents updated.</string>
    <string name="consents_revoke_privacy_title">Withdraw privacy consent?</string>
    <string name="consents_revoke_privacy_msg">Without personal data processing consent you cannot use geoHELP. After saving you must accept privacy again to continue.</string>
    <string name="consents_revoke_privacy_confirm">Withdraw and save</string>
