    <string name="mandown_always_on_title">Fall monitoring</string>
    <string name="mandown_always_on_detail">Tap “Enable MAN DOWN” to start the service (persistent notification). Requires a completed profile, network (Wi‑Fi/mobile data), notifications (Android 13+) and GPS location.</string>
